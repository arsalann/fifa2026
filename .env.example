# ─────────────────────────────────────────────────────────────────────────
# PostHog product analytics (optional). Create a free project at posthog.com,
# then copy the Project API key (starts with "phc_"). Unset = no tracking and
# posthog-js is never even loaded. Recommended: set it in Netlify, not here,
# so local dev doesn't pollute your data.
# ─────────────────────────────────────────────────────────────────────────
VITE_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Region host — match where you created the project: US (default) or EU.
#VITE_POSTHOG_HOST=https://us.i.posthog.com
#VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ─────────────────────────────────────────────────────────────────────────
# Bruin / ingestr pipeline credentials (optional, server-side/local only).
# Do not prefix these with VITE_; they should never be bundled into the app.
# See `.bruin.yml.example` and `pipelines/worldcup_2026/README.md`.
# ─────────────────────────────────────────────────────────────────────────
#MOTHERDUCK_TOKEN=...

# Bruin Cloud on-demand pipeline trigger (server-side Netlify function only).
# Do not prefix with VITE_; the browser must never receive this token.
#BRUIN_CLOUD_API_KEY=...
#BRUIN_CLOUD_PROJECT_ID=01kvdhnz90my4p88y0b8fzbk0z
#BRUIN_CLOUD_PIPELINE=worldcup_2026
#BRUIN_CLOUD_BASE_URL=<Bruin Cloud API base URL>
#BRUIN_TRIGGER_COOLDOWN_MS=90000
#BRUIN_TRIGGER_QUEUE_DEPTH=1
#BRUIN_TRIGGER_QUEUE_COOLDOWN_MS=60000
