default_environment: default

environments:
  default:
    connections:
      motherduck:
        - name: "motherduck-fifa"
          token: "${MOTHERDUCK_TOKEN}"
          database: "fifa"

      # ESPN is keyless and powers the app's live-score overlay.
      espn:
        - name: "espn-worldcup"
          sport: "soccer"
          league: "fifa.world"
          dates: "20260610-20260721"
          limit: 300
