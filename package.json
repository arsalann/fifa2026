{
  "name": "worldcup-teams-stats",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node scripts/run-tests.mjs",
    "pipeline:validate": "bruin validate pipelines/worldcup_2026",
    "pipeline:run": "bruin run pipelines/worldcup_2026 --selector +marts.app_data_manifest --workers 1",
    "pipeline:export": "node scripts/export-bruin-data.mjs",
    "pipeline:refresh": "npm run pipeline:run && npm run pipeline:export",
    "update-data": "node scripts/generate-schedule.mjs",
    "update-icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@duckdb/node-api": "1.5.3-r.3",
    "posthog-js": "^1.387.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.28.1",
    "vite": "^5.4.0"
  }
}
